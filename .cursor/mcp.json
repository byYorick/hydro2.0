{
  "mcpServers": {
    "espressif-docs": {
      "url": "https://mcp.espressif.com/docs"
    },
    "esp-component-registry": {
      "url": "https://components.espressif.com/mcp"
    },
    "mqtt": {
      "command": "uvx",
      "args": [
        "--from",
        "mqtt-mcp-server",
        "python",
        "-m",
        "mqtt_mcp.server"
      ],
      "env": {
        "MQTT_HOST": "127.0.0.1",
        "MQTT_PORT": "1883"
      }
    },
    "postgres": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network",
        "host",
        "crystaldba/postgres-mcp",
        "--access-mode",
        "restricted",
        "postgresql://hydro:hydro@127.0.0.1:5432/hydro_dev"
      ]
    },
    "redis": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network",
        "host",
        "mcp/redis",
        "uv",
        "run",
        "redis-mcp-server",
        "--url",
        "redis://127.0.0.1:6379/0"
      ]
    },
    "laravel-boost": {
      "command": "php",
      "args": [
        "artisan",
        "boost:mcp"
      ],
      "cwd": "${workspaceFolder}/backend/laravel"
    }
  }
}
