{
  "title": "Zone Telemetry",
  "tags": [
    "zones",
    "telemetry"
  ],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 2,
  "refresh": "15s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "— Текущие значения —",
      "type": "text",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## Текущие значения по зонам"
      }
    },
    {
      "id": 1,
      "title": "Текущие значения сенсоров",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT s.zone_id, s.type as sensor_type, s.label, tl.last_value as value, tl.last_quality as quality, tl.updated_at FROM telemetry_last tl JOIN sensors s ON s.id = tl.sensor_id WHERE s.zone_id IS NOT NULL ORDER BY s.zone_id, s.type",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PostgreSQL"
          }
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "zone_id"
          }
        ]
      }
    },
    {
      "id": 101,
      "title": "— pH —",
      "type": "text",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "options": {
        "mode": "markdown",
        "content": "## pH"
      }
    },
    {
      "id": 2,
      "title": "pH по зонам",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT ts.ts::timestamp as time, ts.value::float as value, 'Zone ' || ts.zone_id::text || ' / ' || s.label as metric FROM telemetry_samples ts JOIN sensors s ON s.id = ts.sensor_id WHERE s.type = 'PH' AND ts.ts >= $__timeFrom()::timestamp AND ts.ts <= $__timeTo()::timestamp ORDER BY ts.ts LIMIT 5000",
          "format": "time_series",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PostgreSQL"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 3,
      "title": "EC по зонам",
