          "legendFormat": "{{job}}",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
