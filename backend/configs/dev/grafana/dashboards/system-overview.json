    {
      "id": 20,
      "title": "Активные задачи AE3",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(ae3_active_tasks) or vector(0)",
          "refId": "A",
          "legendFormat": "active tasks",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 21,
      "title": "AE3 Task Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(ae3_task_created_total[5m])) or vector(0)",
          "refId": "A",
          "legendFormat": "created/s",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "expr": "sum(rate(ae3_task_completed_total[5m])) or vector(0)",
          "refId": "B",
          "legendFormat": "completed/s",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        },
        {
          "expr": "sum(rate(ae3_task_failed_total[5m])) or vector(0)",
          "refId": "C",
          "legendFormat": "failed/s",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 22,
      "title": "AE3 Tick Duration p95",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ae3_tick_duration_seconds_bucket[5m]))",
