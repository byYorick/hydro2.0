        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=~\"automation-engine|mqtt-bridge|history-logger\"}[1m])",
