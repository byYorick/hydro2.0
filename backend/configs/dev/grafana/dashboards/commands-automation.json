    {
      "id": 10,
      "title": "Команды по статусу (час)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT DATE_TRUNC('hour', created_at)::timestamp as time, COUNT(*)::float as value, status as metric FROM commands WHERE created_at >= $__timeFrom()::timestamp AND created_at <= $__timeTo()::timestamp GROUP BY DATE_TRUNC('hour', created_at), status ORDER BY time",
          "format": "time_series",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PostgreSQL"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 11,
      "title": "Success Rate по часам",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT DATE_TRUNC('hour', created_at)::timestamp as time, (COUNT(*) FILTER (WHERE status = 'DONE') * 100.0 / NULLIF(COUNT(*), 0))::float as value FROM commands WHERE created_at >= $__timeFrom()::timestamp AND created_at <= $__timeTo()::timestamp GROUP BY DATE_TRUNC('hour', created_at) ORDER BY time",
          "format": "time_series",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PostgreSQL"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        }
      }
