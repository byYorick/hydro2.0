    {
      "id": 1,
      "title": "В очереди (QUEUED)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*)::int as value FROM commands WHERE status = 'QUEUED'",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PostgreSQL"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "QUEUED",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 100,
                "color": "yellow"
              },
              {
                "value": 500,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
