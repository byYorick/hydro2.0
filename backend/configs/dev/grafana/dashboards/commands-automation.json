    {
      "id": 20,
      "title": "Команды по типу (24h)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT cmd, status, COUNT(*)::int as count FROM commands WHERE created_at >= NOW() - INTERVAL '24 hours' GROUP BY cmd, status ORDER BY count DESC LIMIT 30",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PostgreSQL"
          }
        }
      ]
    },
    {
      "id": 21,
      "title": "Последние 50 команд",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 14,
        "x": 10,
        "y": 15
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT cmd_id, zone_id, cmd, status, error_code, created_at, sent_at, ack_at FROM commands ORDER BY created_at DESC LIMIT 50",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PostgreSQL"
          }
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "created_at",
            "desc": true
          }
        ]
      }
