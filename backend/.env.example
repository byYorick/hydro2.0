# Переменные для docker compose (backend/docker-compose.dev.yml).
# Скопируйте: cp .env.example .env  или запустите: make lan-setup
#
# IP хоста в локальной сети (телефон, другой ПК). Оставьте пустым для localhost-only.
LAN_HOST=192.168.1.116

# URL веб-приложения для браузера (nginx :8080). При LAN_HOST — подставьте свой IP.
APP_URL=http://192.168.1.116:8080
VITE_DEV_SERVER_URL=http://192.168.1.116:8080
