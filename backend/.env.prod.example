# Production env для docker compose (backend/docker-compose.prod.yml).
# Скопируйте или сгенерируйте: make prod-setup
#
# ВАЖНО: не коммитьте backend/.env.prod — файл с секретами.

# --- Публичный доступ (браузер, WebSocket, ESP32 MQTT) ---
# Домен или IP сервера без схемы (например greenhouse.example.com или 192.168.1.50)
PUBLIC_HOST=your-server.example.com
# Полный URL веб-приложения (nginx :8080 или reverse proxy :443)
APP_URL=https://your-server.example.com
# http | https — для Vite/Reverb в собранном фронте
PUBLIC_SCHEME=https
PUBLIC_WS_PORT=6001
# true при PUBLIC_SCHEME=https
PUBLIC_WS_TLS=true

# --- Laravel ---
APP_KEY=
# REVERB_ALLOWED_ORIGINS: через запятую, те же origin что у APP_URL
REVERB_ALLOWED_ORIGINS=https://your-server.example.com
SANCTUM_STATEFUL_DOMAINS=your-server.example.com
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

REVERB_APP_ID=app
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_AUTO_START=true

# --- PostgreSQL ---
POSTGRES_USER=hydro
POSTGRES_DB=hydro
POSTGRES_PASSWORD=

# --- API tokens (Python ↔ Laravel) ---
# Можно задать одинаковые значения; setup-prod-env.sh генерирует связку автоматически
PY_API_TOKEN=
PY_INGEST_TOKEN=
LARAVEL_API_TOKEN=

# --- MQTT (сервисы backend) ---
MQTT_MQTT_BRIDGE_PASS=
MQTT_AUTOMATION_ENGINE_PASS=
MQTT_HISTORY_LOGGER_PASS=
# Пароль для узлов ESP32 (user esp32_node в passwords.txt)
MQTT_ESP32_NODE_PASS=

# --- Мониторинг ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
