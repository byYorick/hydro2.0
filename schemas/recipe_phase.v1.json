{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hydro2.local/schemas/recipe_phase/v1.json",
  "title": "Recipe Phase Runtime Payload",
  "description": "Schema for recipe phase runtime payload consumed by AE3. This is NOT a separate automation_config_document namespace — it is the live payload of `grow_cycles.currentPhase` relation merged with recipe phase data. Covers the inputs AE3 reads as `snapshot.phase_targets`, `snapshot.targets`, `snapshot.diagnostics_execution`. Schema version 1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["phase_targets", "targets", "diagnostics_execution"],
  "properties": {
    "phase_targets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ph", "ec"],
      "properties": {
        "ph": { "$ref": "#/$defs/PhTargets" },
        "ec": { "$ref": "#/$defs/EcTargets" },
        "day_night_enabled": { "type": "boolean" },
        "ec_component_ratios": { "$ref": "#/$defs/EcComponentRatios" },
        "extensions": { "$ref": "#/$defs/PhaseTargetsExtensions" }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "irrigation": { "$ref": "#/$defs/IrrigationTargets" },
        "extensions": { "$ref": "#/$defs/TargetsExtensions" }
      }
    },
    "diagnostics_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["two_tank_commands", "fail_safe_guards", "startup"],
      "properties": {
        "two_tank_commands": { "$ref": "#/$defs/TwoTankCommands" },
        "fail_safe_guards": { "$ref": "#/$defs/FailSafeGuards" },
        "startup": { "$ref": "#/$defs/DiagnosticsStartup" }
      }
    }
  },
  "$defs": {
    "PhTargets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "target": { "type": "number", "minimum": 0.0, "maximum": 14.0 },
        "min":    { "type": "number", "minimum": 0.0, "maximum": 14.0 },
        "max":    { "type": "number", "minimum": 0.0, "maximum": 14.0 }
      }
    },
    "EcTargets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "target": { "type": "number", "minimum": 0.0, "maximum": 20.0 },
        "min":    { "type": "number", "minimum": 0.0, "maximum": 20.0 },
        "max":    { "type": "number", "minimum": 0.0, "maximum": 20.0 }
      }
    },
    "EcComponentRatios": {
      "type": "object",
      "description": "Component ratios for EC. `npk_ec_share` = fraction of total EC attributable to NPK phase for two-tank prepare. Required unless ec_dosing_mode == 'single' (see zone_correction schema).",
      "additionalProperties": false,
      "properties": {
        "npk_ec_share": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "PhaseTargetsExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "day_night": {
          "type": "object",
          "description": "Day/night schedule parameters. Structure owned by recipe layer; validation intentionally loose here (no additionalProperties: false) pending dedicated schema.",
          "type": "object"
        }
      }
    },
    "IrrigationTargets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correction_during_irrigation", "correction_slack_sec", "stage_timeout_sec"],
      "properties": {
        "correction_during_irrigation": { "type": "boolean" },
        "correction_slack_sec": { "type": "integer", "minimum": 0, "maximum": 7200 },
        "stage_timeout_sec": { "type": "integer", "minimum": 60, "maximum": 86400 },
        "mode": { "type": "string", "maxLength": 32 },
        "interval": { "type": "integer", "minimum": 0 },
        "duration": { "type": "integer", "minimum": 0 }
      }
    },
    "TargetsExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subsystems": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "irrigation": { "$ref": "#/$defs/IrrigationSubsystem" }
          }
        }
      }
    },
    "IrrigationSubsystem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "recovery"],
      "properties": {
        "decision": { "$ref": "#/$defs/IrrigationDecision" },
        "recovery": { "$ref": "#/$defs/IrrigationRecovery" },
        "safety": {
          "type": "object",
          "description": "Irrigation safety parameters (loose schema; refine in future version).",
          "additionalProperties": true
        },
        "targets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "soil_moisture": {
              "type": "object",
              "description": "Canonical path for soil moisture targets. Legacy path `day_night.soil_moisture` removed in v1.",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "IrrigationDecision": {
      "type": "object",
      "description": "Irrigation decision engine parameters.",
      "additionalProperties": false,
      "required": ["strategy"],
      "properties": {
        "strategy": { "enum": ["task", "smart_soil_v1"] },
        "lookback_sec": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "min_samples": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "stale_threshold_sec": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "hysteresis_percent": { "type": "number", "minimum": 0.0, "maximum": 100.0 }
      }
    },
    "IrrigationRecovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_continue_attempts", "timeout_sec", "max_replays"],
      "properties": {
        "max_continue_attempts": { "type": "integer", "minimum": 1, "maximum": 100 },
        "timeout_sec": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "max_replays": { "type": "integer", "minimum": 0, "maximum": 10 }
      }
    },
    "TwoTankCommands": {
      "type": "object",
      "description": "Per-plan relay command overrides. Plan names are fixed by AE3 two-tank topology; see two_tank_runtime_spec.py _REQUIRED_TWO_TANK_PLAN_CHANNELS.",
      "additionalProperties": false,
      "properties": {
        "irrigation_start":            { "$ref": "#/$defs/CommandList" },
        "irrigation_stop":             { "$ref": "#/$defs/CommandList" },
        "clean_fill_start":            { "$ref": "#/$defs/CommandList" },
        "clean_fill_stop":             { "$ref": "#/$defs/CommandList" },
        "solution_fill_start":         { "$ref": "#/$defs/CommandList" },
        "solution_fill_stop":          { "$ref": "#/$defs/CommandList" },
        "prepare_recirculation_start": { "$ref": "#/$defs/CommandList" },
        "prepare_recirculation_stop":  { "$ref": "#/$defs/CommandList" },
        "irrigation_recovery_start":   { "$ref": "#/$defs/CommandList" },
        "irrigation_recovery_stop":    { "$ref": "#/$defs/CommandList" }
      }
    },
    "CommandList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["channel", "cmd"],
        "properties": {
          "channel": { "type": "string", "maxLength": 64, "minLength": 1 },
          "cmd": { "enum": ["set_relay", "set_pwm", "run_pump"] },
          "params": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "FailSafeGuards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clean_fill_min_check_delay_ms",
        "solution_fill_min_check_delay_ms",
        "solution_fill_max_check_delay_ms",
        "estop_debounce_ms"
      ],
      "properties": {
        "clean_fill_min_check_delay_ms":     { "type": "integer", "minimum": 0, "maximum": 600000 },
        "solution_fill_min_check_delay_ms":  { "type": "integer", "minimum": 0, "maximum": 600000 },
        "solution_fill_max_check_delay_ms":  { "type": "integer", "minimum": 0, "maximum": 600000 },
        "estop_debounce_ms":                  { "type": "integer", "minimum": 0, "maximum": 60000 }
      }
    },
    "DiagnosticsStartup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["irr_state_wait_timeout_sec"],
      "properties": {
        "irr_state_wait_timeout_sec": { "type": "number", "minimum": 0.0, "maximum": 30.0 }
      }
    }
  }
}
