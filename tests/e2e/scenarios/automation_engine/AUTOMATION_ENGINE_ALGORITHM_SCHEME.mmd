    A1-->A2-->A3-->A4-->A5-->A6
    A6--"да"-->A7
    A6--"нет"-->A8-->A9
    A9--"да"-->A10
    A9--"нет"-->A11-->A12
    A12--"да"-->A13-->A16
    A12--"нет"-->A14-->A15-->A16
  end

  subgraph B["B. Контур scheduler/API задач (api.py + SchedulerTaskExecutor)"]
    B1["POST /scheduler/task<br/>lease check + дедуп + due/expires gates"]
    B2["Task accepted -> background execute_scheduler_task()"]
    B3["SchedulerTaskExecutor.execute():<br/>TASK_RECEIVED -> TASK_STARTED -> DECISION_MADE"]
    B4{"decision_policy<br/>(run/skip/retry/fail)"}
    B5["No-action ветка:<br/>skip/retry enqueue + decision alerts"]
    B6["Action ветка:<br/>device task или diagnostics workflow"]
    B7["publish_batch closed-loop:<br/>успех только DONE<br/>(для части команд разрешён NO_EFFECT)"]
    B8["TASK_FINISHED + SCHEDULE_TASK_EXECUTION_FINISHED"]
    B9["sync workflow_phase:<br/>zone_workflow_state + WORKFLOW_PHASE_UPDATED"]
    B1-->B2-->B3-->B4
    B4--"skip/retry/fail"-->B5-->B8-->B9
    B4--"run"-->B6-->B7-->B8-->B9
  end

  subgraph C["C. Diagnostics workflow (two_tank / three_tank / cycle_start)"]
    C1["workflow_validator:<br/>payload_contract_version + explicit workflow"]
    C2["workflow_router:<br/>topology -> two_tank / three_tank / cycle_start"]
    C3["two_tank startup:<br/>startup -> clean_fill_check -> solution_fill_check -> prepare_recirculation_check"]
    C4["two_tank recovery:<br/>irrigation_recovery -> irrigation_recovery_check"]
    C5["cycle_start/refill_check:<br/>nodes online + level/freshness + refill self-task"]
    C6["three_tank -> адаптер к cycle_start"]
