flowchart LR
  subgraph A["A. Непрерывный контур автоматизации зон (main.py)"]
    A1["Старт сервиса: MQTT, CircuitBreaker, CommandTracker, CommandBus, FastAPI"]
    A2["Получение config из Laravel API<br/>+ валидация + cache fallback"]
    A3["Получение активных зон + приоритизация"]
    A4["Адаптивная конкурентность<br/>(расчёт max_concurrent)"]
    A5["Параллельный process_zone(zone_id)"]
